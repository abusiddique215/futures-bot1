<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="refresh" content="{{ refresh_seconds }}">
  <title>{% block title %}Topstep Fleet{% endblock %}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
           max-width: 1200px; margin: 1rem auto; color: #222; padding: 0 1rem; }
    h1 { font-size: 1.5rem; margin: 0 0 0.5rem 0; }
    h2 { font-size: 1.05rem; color: #555; margin: 1.5rem 0 0.5rem 0; }
    .meta { color: #777; font-size: 0.9rem; margin-bottom: 1rem; }
    table { border-collapse: collapse; width: 100%; margin-bottom: 1rem; }
    th, td { padding: 0.4rem 0.6rem; border-bottom: 1px solid #eee;
             text-align: left; font-variant-numeric: tabular-nums; }
    th { background: #fafafa; color: #555; font-weight: 600; }
    tr.disabled td { color: #999; }
    .badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 4px;
             font-size: 0.8rem; font-weight: 600; }
    .badge.running { background: #d4edda; color: #155724; }
    .badge.no_data { background: #f5f5f5; color: #666; }
    .badge.enabled { background: #cfe2ff; color: #084298; }
    .badge.disabled { background: #f5f5f5; color: #666; }
    a { color: #0366d6; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .pos { color: #155724; } .neg { color: #842029; }
  </style>
</head>
<body>
{% block content %}{% endblock %}
</body>
</html>
